<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ajout du champ Centrale dans l'entête de la commande d'achat -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Bouton "Imprimer avec papier-en-tête" dans le header -->
            <xpath expr="//header/button[@name='button_done']" position="after">
                <button name="action_print_pdf_with_background"
                        string="Imprimer avec papier-en-tête"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ('purchase', 'done', 'livre')"
                        icon="fa-print"
                        data-hotkey="y"/>
                <button name="action_marquer_livre"
                        string="Marquer comme livré"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'purchase'"
                        icon="fa-truck"/>
                <button name="action_retour_commande"
                        string="Retour à Commandé"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'livre'"
                        icon="fa-undo"/>
            </xpath>

            <!-- Utilise section_and_note_one2many pour séparer les colonnes articles et description -->
            <!-- tout en gardant le bon affichage des sections et notes -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="widget">section_and_note_one2many</attribute>
            </xpath>
            <xpath expr="//page[@name='products']/field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="widget"></attribute>
            </xpath>
            <xpath expr="//page[@name='products']/field[@name='order_line']/list/field[@name='name']" position="attributes">
                <attribute name="widget">section_and_note_text</attribute>
            </xpath>




            <!-- Champ is_objet présenté comme les champs du groupe (avec label) -->
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="is_objet"/>
            </xpath>

            <!-- Champ Centrale dans l'entête -->
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="is_centrale_id"/>
            </xpath>
            <!-- Champ Centrale dans les lignes -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_qty']" position="before">
                <field name="is_centrale_id" optional="show" widget="many2one_clickable"/>
            </xpath>
        </field>
    </record>

    <!-- Ajout de la Centrale et Objet dans la vue liste (purchase_order_tree) -->
    <record id="view_purchase_order_tree_inherit" model="ir.ui.view">
        <field name="name">purchase.order.list.inherit.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="is_objet" optional="show"/>
            </field>
            <field name="partner_id" position="after">
                <field name="is_centrale_id" optional="show" widget="many2one_clickable"/>
            </field>
        </field>
    </record>

    <!-- Ajout de la Centrale et Objet dans la vue liste KPIs (purchase_order_kpis_tree) -->
    <record id="view_purchase_order_kpis_tree_inherit" model="ir.ui.view">
        <field name="name">purchase.order.kpis.list.inherit.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="is_objet" optional="show"/>
            </field>
            <field name="partner_id" position="after">
                <field name="is_centrale_id" optional="show" widget="many2one_clickable"/>
            </field>
        </field>
    </record>

    <!-- Ajout de la Centrale et Objet dans la vue liste principale (purchase_order_view_tree) -->
    <record id="view_purchase_order_view_tree_inherit" model="ir.ui.view">
        <field name="name">purchase.order.view.list.inherit.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="is_objet" optional="show"/>
            </field>
            <field name="partner_id" position="after">
                <field name="is_centrale_id" optional="show" widget="many2one_clickable"/>
            </field>
        </field>
    </record>

    <!-- Vue Kanban des demandes de prix et commandes, groupée par état, sans annulé -->
    <record id="view_purchase_order_kanban_by_state" model="ir.ui.view">
        <field name="name">purchase.order.kanban.by.state.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    draggable="0"
                    quick_create="false"
                    sample="1">
                <field name="currency_id"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="is_centrale_id"/>
                <field name="is_objet"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between align-items-baseline fw-bold mb-1" style="background-color: #e8f0fe; padding: 3px 6px; border-radius: 4px;">
                                <field name="name"/>
                                <field name="amount_total" widget="monetary" class="ms-2 text-nowrap"/>
                            </div>
                            <div>
                                <field name="partner_id"/>
                            </div>
                            <div t-if="record.is_centrale_id.raw_value">
                                <field name="is_centrale_id"/>
                            </div>
                            <div t-if="record.is_objet.raw_value" class="fst-italic text-muted">
                                <field name="is_objet"/>
                            </div>
                            <div class="mt-1 d-flex justify-content-between align-items-center" style="background-color: #e8f0fe; padding: 3px 6px; border-radius: 4px;">
                                <field name="date_order" options="{'show_time': false}"/>
                                <field name="activity_ids" widget="kanban_activity"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vue Calendrier (Arrivée prévue) des demandes de prix -->
    <record id="view_purchase_order_calendar_date_planned" model="ir.ui.view">
        <field name="name">purchase.order.calendar.date_planned.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <calendar date_start="date_planned" string="Arrivée prévue" mode="month" color="partner_id" quick_create="false">
                <field name="name"/>
                <field name="partner_id" filters="1"/>
                <field name="amount_total" widget="monetary"/>
                <field name="is_centrale_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Action Kanban des demandes de prix -->
    <record id="action_purchase_kanban_by_state" model="ir.actions.act_window">
        <field name="name">Kanban des demandes de prix</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">kanban,list,form,pivot,graph,calendar,activity</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban',   'view_id': ref('view_purchase_order_kanban_by_state')}),
            (0, 0, {'view_mode': 'calendar', 'view_id': ref('view_purchase_order_calendar_date_planned')}),
        ]"/>
        <field name="domain">[('state', '!=', 'cancel')]</field>
        <field name="context">{'group_by': 'state'}</field>
        <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
    </record>

    <!-- Ajout de la Centrale dans la vue search -->
    <record id="view_purchase_order_search_inherit" model="ir.ui.view">
        <field name="name">purchase.order.search.inherit.is_jura</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_search"/>
        <field name="arch" type="xml">
            <field name="product_id" position="after">
                <field name="is_centrale_id"/>
            </field>
            <filter name="vendor" position="before">
                <filter string="Centrale" name="group_by_centrale" domain="[]" context="{'group_by': 'is_centrale_id'}"/>
            </filter>
        </field>
    </record>

</odoo>
