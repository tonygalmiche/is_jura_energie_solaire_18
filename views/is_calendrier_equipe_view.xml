<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="is_calendrier_equipe_list_view" model="ir.ui.view">
        <field name="name">is.calendrier.equipe.list</field>
        <field name="model">is.calendrier.equipe</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="is_calendrier_equipe_form_view" model="ir.ui.view">
        <field name="name">is.calendrier.equipe.form</field>
        <field name="model">is.calendrier.equipe</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="is_calendrier_equipe_action" model="ir.actions.act_window">
        <field name="name">Équipes</field>
        <field name="res_model">is.calendrier.equipe</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
