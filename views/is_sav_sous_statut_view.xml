<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="is_sav_sous_statut_list_view" model="ir.ui.view">
        <field name="name">is.sav.sous.statut.list</field>
        <field name="model">is.sav.sous.statut</field>
        <field name="arch" type="xml">
            <list>
                <field name="state"/>
                <field name="line_ids" widget="many2many_tags" string="Sous-statuts"/>
            </list>
        </field>
    </record>

    <record id="is_sav_sous_statut_form_view" model="ir.ui.view">
        <field name="name">is.sav.sous.statut.form</field>
        <field name="model">is.sav.sous.statut</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="state"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="color" string="Couleur" widget="color_picker"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="is_sav_sous_statut_action" model="ir.actions.act_window">
        <field name="name">Sous-statuts SAV</field>
        <field name="res_model">is.sav.sous.statut</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
