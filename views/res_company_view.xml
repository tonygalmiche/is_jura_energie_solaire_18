<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_jes" model="ir.ui.view">
        <field name="name">res.company.form.jes</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="JES" name="jes">
                    <group>
                        <field name="is_gestionnaire_administrative_id"/>
                    </group>
                    <group>
                        <field name="is_conditions_generales_ids" widget="many2many_binary"/>
                    </group>
                    <group string="PDF">
                        <!-- <field name="is_pdf_background_image" widget="image" class="oe_avatar" options="{'preview_image': 'is_pdf_background_image'}"/> -->
                        <field name="is_pdf_background" filename="is_pdf_background_filename"/>
                    </group>
                    <!-- <group string="Fond PDF découpé (en-tête / corps / pied de page)">
                        <field name="is_pdf_bg_header" widget="image" options="{'preview_image': 'is_pdf_bg_header'}"/>
                        <field name="is_pdf_bg_body" widget="image" options="{'preview_image': 'is_pdf_bg_body'}"/>
                        <field name="is_pdf_bg_footer" widget="image" options="{'preview_image': 'is_pdf_bg_footer'}"/>
                    </group> -->
                </page>
            </xpath>
        </field>
    </record>

</odoo>
